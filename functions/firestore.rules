rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función auxiliar para obtener datos del token (Custom Claims)
    function getRango() { return request.auth.token.rango; }

    // ---------- CARRUSEL (global) ----------
    match /carrusel/{docId} {
      allow read: if true;
      allow write: if request.auth != null && getRango() == 'owner_supremo';
    }

    // ---------- FLYERS (por núcleo) ----------
    match /flyers/{docId} {
      allow read: if request.auth != null &&
        ( getRango() == 'owner_supremo' ||
          getRango() == 'director_nacional' ||
          (getRango() == 'director_regional' && resource.data.estado == request.auth.token.estado) ||
          (resource.data.nucleo == request.auth.token.nucleo)
        );
      allow create: if request.auth != null &&
        ( getRango() == 'owner_supremo' ||
          getRango() == 'director_nacional' ||
          (getRango() == 'director_regional' && request.resource.data.estado == request.auth.token.estado) ||
          (getRango() == 'director_nucleo' && request.resource.data.nucleo == request.auth.token.nucleo) ||
          (getRango() == 'admin' && request.resource.data.nucleo == request.auth.token.nucleo)
        );
      allow update, delete: if request.auth != null &&
        ( getRango() == 'owner_supremo' ||
          getRango() == 'director_nacional' ||
          (getRango() == 'director_regional' && resource.data.estado == request.auth.token.estado) ||
          (getRango() == 'director_nucleo' && resource.data.nucleo == request.auth.token.nucleo) ||
          (getRango() == 'admin' && resource.data.nucleo == request.auth.token.nucleo)
        );
    }

    // Añadir aquí reglas para otras colecciones (partituras, eventos, etc.) siguiendo el mismo patrón
  }
}
